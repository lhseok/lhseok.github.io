---
import Default from '../layouts/Default.astro';
import { info } from '../data/info';
import { skills } from '../data/skills';
import { career } from '../data/career';
---

<Default title="About">
  <h1 class="section-title"><a href="/" class="prompt-leehoseok">leehoseok</a><span class="prompt-at-section">@<a href="/about">about</a></span>&gt;<span class="cursor"></span></h1>

  <div class="about-intro" style="margin-bottom: 60px;">
    <p style="font-size: 18px; color: #ccc; margin-bottom: 20px;">{info.intro}</p>
  </div>

  <h2 class="section-title" style="font-size: 24px;">Skills</h2>
  <div class="skills-grid" style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 60px;">
    {skills.map(skill => (
      <span style="background: #222; border: 1px solid #333; padding: 5px 15px; border-radius: 20px; font-size: 14px;">{skill.name}</span>
    ))}
  </div>

  <h2 class="section-title" style="font-size: 24px;">Career</h2>
  <div class="career-list">
    {career.map(item => (
      <div class="career-item">
        <h3 class="company">{item.company}</h3>
        <p class="period">{item.period}<span class="pipe-separator">|</span>{item.role}<span class="pipe-separator">|</span>{item.position}</p>
      </div>
    ))}
  </div>
</Default>
